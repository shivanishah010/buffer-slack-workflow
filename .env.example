# Buffer API Token
# Get this from: https://publish.buffer.com/settings/api
BUFFER_API_TOKEN=your_buffer_api_token_here

# Buffer Organization ID
# You'll get this by running: npm run get-org-id
BUFFER_ORG_ID=your_organization_id_here

# Slack Webhook URL
# Create an incoming webhook in your Slack workspace
# https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL